# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Vercel Blob Storage (for file uploads and voice messages)
# Get token from: https://vercel.com/dashboard/stores
VITE_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Socket.IO Server (for video call signaling)
VITE_SOCKET_SERVER_URL=http://localhost:3001

# ExpressTURN Configuration (for video calls)
# Get free credentials from: https://www.expressturn.com/
VITE_TURN_URL=turn:a.relay.metered.ca:80
VITE_TURN_USERNAME=your_expressturn_username
VITE_TURN_CREDENTIAL=your_expressturn_credential
