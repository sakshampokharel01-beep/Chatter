rules_version = '2';

// Firebase Storage Security Rules for Chatter App
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // File size limits
    function isValidFileSize() {
      // Max 10MB for files, 5MB for voice messages
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    function isValidVoiceSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }
    
    // Allowed file types
    function isValidImageType() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isValidAudioType() {
      return request.resource.contentType.matches('audio/.*');
    }
    
    function isValidFileType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType.matches('audio/.*') ||
             request.resource.contentType.matches('video/.*') ||
             request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('application/msword') ||
             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*') ||
             request.resource.contentType.matches('text/.*');
    }
    
    // DM Files: /dms/{dmId}/files/{userId}/{fileName}
    match /dms/{dmId}/files/{userId}/{fileName} {
      // Allow read if user is signed in
      allow read: if isSignedIn();
      
      // Allow upload if user is the owner and file is valid
      allow create: if isSignedIn() && 
        isOwner(userId) &&
        isValidFileSize() &&
        isValidFileType();
      
      // Allow delete only by owner within 1 hour
      allow delete: if isSignedIn() && 
        isOwner(userId) &&
        resource.timeCreated > request.time - duration.value(1, 'h');
    }
    
    // Voice Messages: /dms/{dmId}/voice/{userId}/{fileName}
    match /dms/{dmId}/voice/{userId}/{fileName} {
      // Allow read if user is signed in
      allow read: if isSignedIn();
      
      // Allow upload if user is the owner and audio is valid
      allow create: if isSignedIn() && 
        isOwner(userId) &&
        isValidVoiceSize() &&
        isValidAudioType();
      
      // Allow delete only by owner within 1 hour
      allow delete: if isSignedIn() && 
        isOwner(userId) &&
        resource.timeCreated > request.time - duration.value(1, 'h');
    }
    
    // Profile Pictures: /profiles/{userId}/avatar
    match /profiles/{userId}/avatar {
      allow read: if true; // Public read
      allow write: if isSignedIn() && 
        isOwner(userId) &&
        isValidImageType() &&
        request.resource.size < 2 * 1024 * 1024; // 2MB limit for avatars
    }
    
    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
