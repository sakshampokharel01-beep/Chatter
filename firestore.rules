rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. HELPERS
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    // Rate limiting helper - REMOVED (can't query in rules)
    // Rate limiting is enforced by Firebase's built-in abuse detection
    // and by limiting operations per user

    // 2. GLOBAL CHAT
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500 &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
      allow update: if false;
    }

    // 3. USER PROFILES (Secured + Rate Limit Tracking + Anti-Spam + Block Removed Users)
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.displayName.size() <= 64 &&
        // Prevent removed users from creating new profiles
        !exists(/databases/$(database)/documents/deletedUsers/$(uid)) &&
        // Prevent rapid account creation from same IP (Firebase limitation workaround)
        request.time > request.resource.data.get('createdAt', timestamp.value(0)) + duration.value(0, 's');
      allow update: if isOwner(uid) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 64 &&
        // Prevent removed users from updating profiles
        !exists(/databases/$(database)/documents/deletedUsers/$(uid)) &&
        // Prevent updating too frequently (anti-spam)
        request.time > resource.data.lastSeen + duration.value(1, 's');
      allow delete: if isAdmin(); // Allow admins to delete user profiles
    }

    // 4. FRIEND REQUESTS (Backend Validation Only - Firebase handles rate limiting)
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && 
        (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow create: if isSignedIn() && 
        request.resource.data.from == request.auth.uid &&
        request.resource.data.to != request.auth.uid &&
        request.resource.data.from is string &&
        request.resource.data.to is string;
      allow delete: if isSignedIn() && 
        (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow update: if false;
    }

    // 5. FRIENDS
    match /friends/{friendshipId} {
      allow read: if isSignedIn() && 
        request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && 
        request.auth.uid in request.resource.data.users &&
        request.resource.data.users.size() == 2;
      allow delete: if isSignedIn() && 
        request.auth.uid in resource.data.users;
      allow update: if false;
    }

    // 6. PRIVATE DMs (Strictly Participant-Only + Must be Friends)
    match /dms/{convId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }
      function isNewParticipant() {
        return request.auth.uid in request.resource.data.participants;
      }

      allow read: if isSignedIn() && isParticipant();
      allow create: if isSignedIn() && 
        isNewParticipant() &&
        request.resource.data.participants.size() == 2;
      allow update, delete: if false;
      
      match /messages/{mId} {
        allow read: if isSignedIn() && 
          get(/databases/$(database)/documents/dms/$(convId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/dms/$(convId)).data.participants.hasAny([request.auth.uid]) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 500 &&
          request.resource.data.uid == request.auth.uid;
        allow update: if isSignedIn() &&
          get(/databases/$(database)/documents/dms/$(convId)).data.participants.hasAny([request.auth.uid]) &&
          // Only allow updating seenBy, seenAt, deliveredTo, and deliveredAt fields
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy', 'seenAt', 'deliveredTo', 'deliveredAt']) &&
          // Ensure user is adding themselves to seenBy or deliveredTo
          (request.auth.uid in request.resource.data.get('seenBy', []) || 
           request.auth.uid in request.resource.data.get('deliveredTo', []));
        allow delete: if false;
      }
    }

    // 7. ADMIN DATA
    match /admins/{u}        { 
      allow read: if isSignedIn(); // Allow any signed-in user to check admin status
      allow list: if isSignedIn(); // Allow listing admins collection
      allow write: if isAdmin(); 
    }
    match /blockedUsers/{u}  { 
      allow read: if isOwner(u) || isAdmin(); 
      allow list: if isAdmin(); // Allow admins to list blocked users
      allow write: if isAdmin(); 
    }
    match /deletedUsers/{u}  { 
      allow read: if isOwner(u) || isAdmin(); 
      allow list: if isAdmin(); // Allow admins to list deleted users
      allow write: if isAdmin(); 
    }
  }
}
