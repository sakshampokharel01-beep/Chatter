rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth.token.email == 'sakshampokharel01@gmail.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Check blocked users collection — blocked users cannot post anything
    function isNotBlocked() {
      return !exists(/databases/$(database)/documents/blockedUsers/$(request.auth.uid));
    }

    function validMessage(data) {
      return data.text is string
        && data.text.size() >= 1
        && data.text.size() <= 500
        && data.uid == request.auth.uid
        && data.createdAt == request.time
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 64
        // Only exactly these fields allowed — no extra data can be injected
        && data.keys().hasOnly(['text', 'uid', 'displayName', 'photoURL', 'createdAt', 'isAnonymous', 'isAdmin']);
    }

    function validDMMessage(data) {
      return data.text is string
        && data.text.size() >= 1
        && data.text.size() <= 500
        && data.uid == request.auth.uid
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && data.createdAt == request.time
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 64
        // Only exactly these fields allowed
        && data.keys().hasOnly(['text', 'uid', 'displayName', 'photoURL', 'createdAt']);
    }

    // ── Global chat messages ────────────────────────────────────
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBlocked() && validMessage(request.resource.data);
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ── Registered users directory ──────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create,
            update: if isSignedIn()
                    && isOwner(uid)
                    && isNotBlocked()
                    && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
      allow delete: if false;
    }

    // ── Admins directory ────────────────────────────────────────
    // Only the super-admin can grant/revoke admin; everyone signed in can read.
    match /admins/{uid} {
      allow read:  if isSignedIn();
      allow write: if request.auth.token.email == 'sakshampokharel01@gmail.com';
    }

    // ── Blocked users ───────────────────────────────────────────
    // Only admin can write (block/unblock); a user can only read their own status.
    match /blockedUsers/{uid} {
      allow read:  if isSignedIn() && (isOwner(uid) || isAdmin());
      allow write: if isAdmin();
    }

    // ── Deleted users ────────────────────────────────────────────
    // Admin can remove a user; any signed-in user can read (needed to filter DM list).
    match /deletedUsers/{uid} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Direct message conversations ────────────────────────────
    match /dms/{convId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }
      function isParticipantNew() {
        return request.auth.uid in request.resource.data.participants;
      }
      function notAnon() {
        return !request.auth.token.firebase.sign_in_provider.matches('anonymous');
      }

      allow read:   if isSignedIn() && notAnon() && isParticipant();
      allow create: if isSignedIn() && notAnon() && isNotBlocked() && isParticipantNew()
                    && request.resource.data.participants.size() == 2;
      allow update,
            delete: if false;

      // DM messages sub-collection
      match /messages/{msgId} {
        allow read:   if isSignedIn() && notAnon()
                      && request.auth.uid in get(/databases/$(database)/documents/dms/$(convId)).data.participants;
        allow create: if isSignedIn() && notAnon() && isNotBlocked()
                      && request.auth.uid in get(/databases/$(database)/documents/dms/$(convId)).data.participants
                      && validDMMessage(request.resource.data);
        allow update,
              delete: if false;
      }
    }
  }
}
