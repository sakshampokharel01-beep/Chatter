rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == 'sakshampokharel01@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 2. GLOBAL CHAT: Anyone signed in can read/post; only Admin can delete.
    match /messages/{msgId} {
      allow read, create: if isSignedIn();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // 3. USER PROFILES: Diagnostic Mode — open write for testing
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow write:  if isOwner(uid) || isAdmin();
      allow delete: if false;
    }

    // ── 4. ADMINISTRATIVE DATA ─────────────────────────────────
    // Only admins can see the lists of blocked/deleted users.
    // Regular users can only check if THEY THEMSELVES are blocked/deleted.
    match /admins/{uid}       { allow read, write: if isAdmin(); }
    match /blockedUsers/{uid} { allow read: if isOwner(uid) || isAdmin(); allow write: if isAdmin(); }
    match /deletedUsers/{uid} { allow read: if isOwner(uid) || isAdmin(); allow write: if isAdmin(); }

    // ── 5. DIRECT MESSAGES ─────────────────────────────────────
    // CRITICAL: Only the two participants can EVER read these messages.
    match /dms/{convId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }
      function isNewParticipant() {
        return request.auth.uid in request.resource.data.participants;
      }

      allow read:   if isSignedIn() && isParticipant();
      allow create: if isSignedIn() && isNewParticipant();
      allow update, 
            delete: if false;

      // DM Sub-messages
      match /messages/{mId} {
        allow read: if isSignedIn() && 
          get(/databases/$(database)/documents/dms/$(convId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/dms/$(convId)).data.participants.hasAny([request.auth.uid]);
      }
    }
  }
}
